<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Library</OutputType>
    <TargetFramework>net472</TargetFramework>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Dependency/Dependency.csproj" />
    <!-- This direct reference to TransitiveDependency is unused by Library's code.
         With GetUsedAssemblyReferences, it would falsely appear as "used" because
         Dependency uses it. Symbol-based detection correctly identifies it as removable. -->
    <ProjectReference Include="../TransitiveDependency/TransitiveDependency.csproj" />
  </ItemGroup>
</Project>
